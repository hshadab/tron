# ICME Preflight API
ICME_API_KEY=           # From /v1/createUserCard ($5, includes 325 credits)
ICME_POLICY_ID=         # From scripts/setup_policy.py (/v1/makeRules output)

# TRON Nile Testnet — Agent Wallet
TRON_PRIVATE_KEY=       # Hex private key (64 chars), generated by scripts/setup_wallet.py
TRON_WALLET_ADDRESS=    # Base58check address, generated by scripts/setup_wallet.py

# TRON Nile Testnet — Vendor Wallet (receives payments)
VENDOR_ADDRESS=         # Base58check address, generated by scripts/setup_wallet.py

# TRON Nile Testnet — Facilitator Wallet (pays gas for x402 settlement)
FACILITATOR_PRIVATE_KEY=  # Hex private key (64 chars), generated by scripts/setup_wallet.py
FACILITATOR_ADDRESS=      # Base58check address, generated by scripts/setup_wallet.py
